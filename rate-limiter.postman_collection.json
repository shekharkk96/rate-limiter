    },
    {
      "name": "Spam 15 Requests (Test Rate Limit)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-KEY",
            "value": "user123"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/api/data",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "data"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "for(let i=0;i<15;i++) {",
              "    pm.sendRequest({",
              "        url: 'http://localhost:8080/api/data',",
              "        method: 'GET',",
              "        header: {'X-API-KEY': 'user123'}",
              "    }, function (err, res) {",
              "        console.log('Response ' + i + ': ' + res.code);",
              "    });",
              "}"
            ]
          }
        }
      ]
    }
  ]
